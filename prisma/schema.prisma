// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// prisma를 통해 사용할 DB source 종류를 기록
datasource db {
  provider = "mysql"
  relationMode = "prisma"
}

// 이 아랫부분에는 내가 실제 데이터베이스에 사용할 모델링을 기재 -> prisma의 문법을 통해

enum GenderType {
  MALE
  FEMALE
}

enum RoleType {
  ADMIN
  USER
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

// model 키워드는 Javascript에서는 객체가 되며, DB에서는 테이블이 됨
// 이 안에 기재하는 건, [칼럼명] [타입] [옵션] 으로 작성하고
// 옵션 -----
// @id : primary key
// @default : default
// @unique : unique
// @updatedAt : 해당 칼럼이 수정될 때 자동으로 들어가는 수정 시간 갱신 옵션
model User {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now()) // 삽입할 때 기본값으로 삽입 시간이 기록
  updatedAt   DateTime   @updatedAt // 수정할 때 기본적으로 수정 시간이 기록
  deletedAt   DateTime? // 타입에 ? 를 넣으면 null을 허용한다는 뜻
  username    String     @unique
  password    String
  name        String
  nickname    String     @unique
  email       String     @unique
  phoneNumber String?
  birthdate   DateTime?
  gender      GenderType
  role        RoleType   @default(USER) // 삽입할 때 기본값으로 USER 기록

  posts Post[]
}

model Category {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  name      String
  status    CategoryStatus @default(ACTIVE)

  post Post[]
}

// Post 테이블과 다른 테이블의 연관성을 생각해봐야 함
// 해당 데이터를 삭제해도 될 때에는, 1. 자식 테이블이 없을 때 (연관성이 아ㅖ 존재치 않을 때)
// 2. 자식 테이블까지 고려했을 때에도 중요하지 않을 때
// 3. Post의 경우 Replies나, like 등 테이블과 연관성이 있다고 판단하더라도
// 삭제해도 괜찮은 데이터들임 => 소프트 삭제를 하든, 진짜 삭제 처리를 하든, 문제는 없을 것이다라고 가정
// 1번, 2번 중 개발자 마음
// Prisma에서는 부모 데이터가 삭제되면, 자식 데이터까지 모두 삭제하는 기능을 제공
model Post {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt  DateTime?
  title     String // varchar(255)       
  content   String    @db.Text // Javascript에서는 String으로 동작하지만, DB 칼럼은 Text
  views     Int       @default(0) // 조회수

  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  // relation을 맺는데, 이 글을 작성한 부모의 id값이 적혀지는 칼럼은 userId이고, 그 값으로 부모 테이블의 조회 대상 갈럼은 id이다
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
}
